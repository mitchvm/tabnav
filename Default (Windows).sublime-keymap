    },
    { 
        // reduce selection downwards
        "keys": ["alt+shift+down"],
        "command": "tabnav_reduce_selection",
        "args": { "direction": "down" },
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode", "operand": "false" }
        ]
    },

    // #### TabNav: Enter/Exit Cell Edit Mode ####

    {
        // Enter cell edit mode, retaining current cell contents
        "keys": ["f2"],
        "command": "tabnav_edit_cell",
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode", "operand": "false" }
        ]
    },
    {
        // Enter cell edit mode, replacing contents with the key's character
        "keys": ["<character>"],
        "command": "tabnav_edit_cell",
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode", "operand": "false" }
        ]
    },
    {
        // Exit cell edit mode
        "keys": ["escape"],
        "command": "tabnav_exit_cell",
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode" }
        ]
    },

    // #### TabNav: Cell Edit move cursor ####
    { 
        // move to start of cell
        "keys": ["home"],
        "command": "tabnav_move_cursor_current",
        "args": { "direction": "left" },
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode" }
        ]
    },
    { 
        // move to cell on right
        "keys": ["end"],
        "command": "tabnav_move_cursor_current",
        "args": { "direction": "right" },
        "context": [ 
            { "key": "is_tabnav_context", "match_all": "true"},
            { "key": "is_tabnav_cell_nav_mode" },
            { "key": "is_tabnav_cell_edit_mode" }
        ]
    },
